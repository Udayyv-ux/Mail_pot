# Database (Use postgresql://... for Railway/AWS RDS)
DATABASE_URL=postgresql://user:password@localhost:5432/mailpot

# Security (Generate a random string for this in production)
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Google OAuth & Service Account
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "..."}

# Admin Account Configuration
# Comma-separated list of emails that will automatically get Super Admin rights upon logging in
SUPER_ADMIN_EMAIL=your_admin_email@gmail.com

# Email Defaults (Fallback SMTP)
DEFAULT_SMTP_EMAIL=your_smtp_email@gmail.com
DEFAULT_SMTP_PASSWORD=your_app_password

# AI Integrations
GROQ_API_KEY=gsk_your_groq_api_key

# Payments (Razorpay)
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Application URLs
APP_NAME=MailPilot
# The public URL where the backend is hosted (e.g. https://api.yourdomain.com or Railway URL)
APP_URL=http://localhost:8000
# The public URL where the frontend is hosted
FRONTEND_URL=http://localhost:8000
