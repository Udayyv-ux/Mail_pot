lubhouses | 8 Acres Central Courtyard</td></tr>\n              </table>\n\n              <table width=\"100%\" cellpadding=\"20\" cellspacing=\"0\" border=\"0\" style=\"background-color:#f8f9fa; border-radius:8px; margin-top:25px; border-left: 4px solid #007BFF;\">\n                <tr>\n                  <td>\n                    <h3 style=\"margin:0; color:#d32f2f; font-size: 20px;\">\n                      \ud83d\udcb0 Launch Price: \u20b95,499/sft*\n                    </h3>\n                    <p style=\"margin:10px 0 0; line-height:1.7; font-size: 15px;\">\n                      \u2714 Includes Amenities<br>\n                      \u2714 1 Car Parking Included<br>\n                      \u2714 Infrastructure Charges Included<br>\n                      <strong>\u2714 First 50 Bookings Only</strong>\n                    </p>\n                  </td>\n                </tr>\n              </table>\n\n              <div style=\"margin-top: 30px; padding: 15px; background-color: #f1f8ff; border-radius: 8px;\">\n                <p style=\"margin: 0 0 8px 0; font-size:15px; line-height:1.6;\">\n                  \u2705 <strong>Phase-1:</strong> Only 2 Exclusive Towers Open\n                </p>\n                <p style=\"margin: 0 0 8px 0; font-size:15px; line-height:1.6;\">\n                  \ud83d\udcc5 <strong>Handover:</strong> Dec 2029\n                </p>\n                <p style=\"margin: 0; font-size:15px; line-height:1.6; color: #0056b3;\">\n                  \u2728 <em>Early Investor Advantage with High Appreciation Potential</em>\n                </p>\n              </div>\n\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin-top:35px;\">\n                <tr>\n                  <td align=\"center\">\n                    <a href=\"tel:8977768565\" \n                      style=\"background-color:#007BFF; color:#ffffff; text-decoration:none; padding:15px 30px; border-radius:6px; font-size:16px; font-weight:bold; display:inline-block; box-shadow: 0 4px 6px rgba(0, 123, 255, 0.2);\">\n                      \ud83d\udcde Contact for Pricing & Floor Plans\n                    </a>\n                    <p style=\"margin-top: 15px; font-size: 14px; color: #555555;\">Or call directly: <strong>89777 68565</strong></p>\n                  </td>\n                </tr>\n              </table>\n\n            </td>\n          </tr>\n        </table>\n        \n        <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"margin-top: 20px;\">\n            <tr>\n                <td align=\"center\" style=\"font-size:12px; color:#999999; font-family:Arial, sans-serif;\">\n                    <p>\u00a9 2026 Premium Real Estate. All rights reserved.</p>\n                </td>\n            </tr>\n        </table>\n\n      </td>\n    </tr>\n  </table>\n\n</body>\n</html>"}, "Kondapur": {"subject": "Invest in Kondapur", "body": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Luxury 3BHK Living in Kondapur</title>\n</head>\n\n<body style=\"margin:0; padding:0; background:#f4f4f4; font-family:Arial, sans-serif;\">\n\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" bgcolor=\"#f4f4f4\">\n<tr>\n<td align=\"center\">\n\n<table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\"\nstyle=\"background:#ffffff; margin:30px auto; border-radius:12px; overflow:hidden;\">\n\n  <!-- Banner Image -->\n  <tr>\n    <td>\n      <img src=\"https://i.postimg.cc/JhTPZfbN/Kondapur.jpg\"\n      alt=\"Luxury Project\"\n      width=\"100%\"\n      style=\"display:block;\">\n    </td>\n  </tr>\n\n  <!-- Content -->\n  <tr>\n    <td style=\"padding:40px; color:#333333;\">\n\n      <!-- CORRECTED PLACEHOLDER -->\n      <p style=\"font-size:16px; margin-top:0;\">\n        Dear {first_name},\n      </p>\n\n      <h2 style=\"margin:0 0 20px; color:#111111; line-height:1.4;\">\n        \ud83c\udfd9\ufe0f Luxury 3BHK Living in Kondapur\n      